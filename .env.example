# Copy to .env and fill in real values. Never commit .env.

# Pinterest Ads API — OAuth with refresh token (auto-refreshed on 401)
# Access token: ~30-day TTL, rotated automatically by the digest on auth failure.
# Refresh token: ~1-year TTL. When it expires, re-do the OAuth authorize flow.
# App ID + secret: needed so the digest can mint new access tokens server-side.
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=
PINTEREST_AD_ACCOUNT_ID=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Meta Marketing API (Week 2)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# TikTok Business API (Week 2)
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Slack incoming webhook — the digest posts here
SLACK_WEBHOOK_URL=

# Optional: set to 1 to print Block Kit JSON to stdout instead of posting
DIGEST_DRY_RUN=
